APP_ENV=development
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:8080
LOG_LEVEL=info
SHUTDOWN_TIMEOUT=10s

# Leave blank to boot without Postgres.
# For offline local development, the compose profile below exposes:
# postgres://cerulia:cerulia@localhost:5432/cerulia?sslmode=disable
DATABASE_URL=
DATABASE_URL_POOLED=
DATABASE_URL_DIRECT=
DATABASE_MAX_CONNS=10
DATABASE_MIN_CONNS=0
DATABASE_PING_TIMEOUT=3s
MIGRATIONS_DIR=migrations

# Reserved for the phase 0 blob abstraction.
BLOB_BACKEND=disabled
BLOB_LOCAL_DIR=.local/blob
R2_ACCOUNT_ID=
R2_ASSET_BUCKET=
R2_SECRET_BUCKET=
R2_AUDIT_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
