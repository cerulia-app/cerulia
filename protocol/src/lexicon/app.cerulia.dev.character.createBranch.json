{
	"lexicon": 1,
	"id": "app.cerulia.dev.character.createBranch",
	"defs": {
		"main": {
			"type": "procedure",
			"description": "Create character branch.",
			"input": {
				"encoding": "application/json",
				"schema": {
					"type": "object",
					"required": ["sourceBranchRef", "branchKind", "branchLabel"],
					"properties": {
						"sourceBranchRef": {
							"type": "string",
							"format": "at-uri"
						},
						"branchKind": {
							"type": "string",
							"knownValues": ["campaign-fork", "local-override"]
						},
						"branchLabel": {
							"type": "string",
							"maxLength": 640
						},
						"visibility": {
							"type": "string",
							"knownValues": ["draft", "public"]
						}
					}
				}
			},
			"output": {
				"encoding": "application/json",
				"schema": {
					"type": "ref",
					"ref": "app.cerulia.dev.defs#mutationAck"
				}
			}
		}
	}
}
