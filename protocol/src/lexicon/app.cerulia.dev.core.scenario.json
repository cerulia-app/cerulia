{
	"lexicon": 1,
	"id": "app.cerulia.dev.core.scenario",
	"defs": {
		"main": {
			"type": "record",
			"key": "any",
			"record": {
				"type": "object",
				"properties": {
					"title": {
						"type": "string",
						"maxLength": 640
					},
					"rulesetNsid": {
						"type": "string",
						"format": "nsid"
					},
					"recommendedSheetSchemaPin": {
						"type": "ref",
						"ref": "app.cerulia.dev.defs#exactRecordPin"
					},
					"sourceCitationUri": {
						"type": "string",
						"format": "uri"
					},
					"summary": {
						"type": "string",
						"maxLength": 3000
					},
					"ownerDid": {
						"type": "string",
						"format": "did"
					},
					"createdAt": {
						"type": "string",
						"format": "datetime"
					},
					"updatedAt": {
						"type": "string",
						"format": "datetime"
					}
				},
				"required": ["title", "ownerDid", "createdAt", "updatedAt"]
			}
		}
	}
}
