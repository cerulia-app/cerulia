{
	"lexicon": 1,
	"id": "app.cerulia.dev.scenario.update",
	"defs": {
		"main": {
			"type": "procedure",
			"description": "Update scenario.",
			"input": {
				"encoding": "application/json",
				"schema": {
					"type": "object",
					"required": ["scenarioRef"],
					"properties": {
						"scenarioRef": {
							"type": "string",
							"format": "at-uri"
						},
						"title": {
							"type": "string",
							"maxLength": 640
						},
						"rulesetNsid": {
							"type": "string",
							"format": "nsid"
						},
						"recommendedSheetSchemaPin": {
							"type": "ref",
							"ref": "app.cerulia.dev.defs#exactRecordPin"
						},
						"sourceCitationUri": {
							"type": "string",
							"format": "uri"
						},
						"summary": {
							"type": "string",
							"maxLength": 3000
						}
					}
				}
			},
			"output": {
				"encoding": "application/json",
				"schema": {
					"type": "ref",
					"ref": "app.cerulia.dev.defs#mutationAck"
				}
			}
		}
	}
}
