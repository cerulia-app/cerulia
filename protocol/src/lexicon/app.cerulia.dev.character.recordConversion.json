{
	"lexicon": 1,
	"id": "app.cerulia.dev.character.recordConversion",
	"defs": {
		"main": {
			"type": "procedure",
			"description": "Record character conversion.",
			"input": {
				"encoding": "application/json",
				"schema": {
					"type": "object",
					"required": [
						"characterBranchRef",
						"expectedRevision",
						"targetRulesetNsid",
						"targetSheetSchemaRef",
						"convertedAt"
					],
					"properties": {
						"characterBranchRef": {
							"type": "string",
							"format": "at-uri"
						},
						"expectedRevision": {
							"type": "integer",
							"minimum": 1
						},
						"targetRulesetNsid": {
							"type": "string",
							"format": "nsid"
						},
						"targetSheetSchemaRef": {
							"type": "string",
							"format": "at-uri"
						},
						"convertedAt": {
							"type": "string",
							"format": "datetime"
						},
						"conversionContractRef": {
							"type": "string",
							"format": "uri"
						},
						"note": {
							"type": "string",
							"maxLength": 3000
						}
					}
				}
			},
			"output": {
				"encoding": "application/json",
				"schema": {
					"type": "ref",
					"ref": "app.cerulia.dev.defs#mutationAck"
				}
			}
		}
	}
}
