{
  "defs": {
    "main": {
      "errors": [
        {
          "name": "InvalidRequest"
        },
        {
          "name": "Unauthorized"
        },
        {
          "name": "Forbidden"
        },
        {
          "name": "NotFound"
        },
        {
          "name": "UnsupportedRuleset"
        },
        {
          "name": "InternalError"
        }
      ],
      "input": {
        "encoding": "application/json",
        "schema": {
          "properties": {
            "conversionContractRef": {
              "format": "uri",
              "type": "string"
            },
            "conversionContractVersion": {
              "type": "integer"
            },
            "convertedAt": {
              "ref": "app.cerulia.defs#datetime",
              "type": "ref"
            },
            "convertedByDid": {
              "ref": "app.cerulia.defs#did",
              "type": "ref"
            },
            "note": {
              "type": "string"
            },
            "requestId": {
              "ref": "app.cerulia.defs#requestId",
              "type": "ref"
            },
            "reuseGrantRef": {
              "ref": "app.cerulia.defs#reuseGrantRef",
              "type": "ref"
            },
            "sourceBranchRef": {
              "ref": "app.cerulia.defs#characterBranchRef",
              "type": "ref"
            },
            "sourceEffectiveRuleProfileRefs": {
              "items": {
                "ref": "app.cerulia.defs#ruleProfileRef",
                "type": "ref"
              },
              "type": "array"
            },
            "sourceEpisodeRefs": {
              "items": {
                "ref": "app.cerulia.defs#characterEpisodeRef",
                "type": "ref"
              },
              "type": "array"
            },
            "sourceRulesetManifestRef": {
              "ref": "app.cerulia.defs#rulesetManifestRef",
              "type": "ref"
            },
            "sourceSheetRef": {
              "ref": "app.cerulia.defs#characterSheetRef",
              "type": "ref"
            },
            "sourceSheetVersion": {
              "type": "integer"
            },
            "supersedesRef": {
              "ref": "app.cerulia.defs#characterConversionRef",
              "type": "ref"
            },
            "targetBranchRef": {
              "ref": "app.cerulia.defs#characterBranchRef",
              "type": "ref"
            },
            "targetCampaignRef": {
              "ref": "app.cerulia.defs#campaignRef",
              "type": "ref"
            },
            "targetEffectiveRuleProfileRefs": {
              "items": {
                "ref": "app.cerulia.defs#ruleProfileRef",
                "type": "ref"
              },
              "type": "array"
            },
            "targetRulesetManifestRef": {
              "ref": "app.cerulia.defs#rulesetManifestRef",
              "type": "ref"
            },
            "targetSheetRef": {
              "ref": "app.cerulia.defs#characterSheetRef",
              "type": "ref"
            },
            "targetSheetVersion": {
              "type": "integer"
            }
          },
          "required": [
            "sourceSheetRef",
            "sourceSheetVersion",
            "sourceRulesetManifestRef",
            "sourceEffectiveRuleProfileRefs",
            "targetSheetRef",
            "targetSheetVersion",
            "targetBranchRef",
            "targetRulesetManifestRef",
            "targetEffectiveRuleProfileRefs",
            "conversionContractRef",
            "conversionContractVersion",
            "convertedByDid",
            "convertedAt",
            "requestId"
          ],
          "type": "object"
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "ref": "app.cerulia.defs#mutationAck",
          "type": "ref"
        }
      },
      "type": "procedure"
    }
  },
  "id": "app.cerulia.rpc.recordCharacterConversion",
  "lexicon": 1
}
