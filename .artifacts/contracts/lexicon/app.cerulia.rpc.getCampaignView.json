{
  "defs": {
    "main": {
      "errors": [
        {
          "name": "NotFound"
        }
      ],
      "output": {
        "encoding": "application/json",
        "schema": {
          "properties": {
            "activeBranches": {
              "items": {
                "ref": "app.cerulia.defs#branchSummary",
                "type": "ref"
              },
              "type": "array"
            },
            "archivedCounts": {
              "properties": {
                "episodes": {
                  "type": "integer"
                },
                "publications": {
                  "type": "integer"
                }
              },
              "type": "object"
            },
            "campaign": {
              "ref": "app.cerulia.defs#campaignSummary",
              "type": "ref"
            },
            "defaultReusePolicy": {
              "ref": "app.cerulia.defs#reusePolicyKind",
              "type": "ref"
            },
            "mode": {
              "enum": [
                "owner-steward",
                "public"
              ],
              "type": "string"
            },
            "publishedArtifacts": {
              "items": {
                "ref": "app.cerulia.defs#publicationSummaryRow",
                "type": "ref"
              },
              "type": "array"
            },
            "recentContinuity": {
              "items": {
                "ref": "app.cerulia.defs#episodeSummary",
                "type": "ref"
              },
              "type": "array"
            },
            "ruleProvenance": {
              "properties": {
                "rulesetManifestRef": {
                  "ref": "app.cerulia.defs#rulesetManifestRef",
                  "type": "ref"
                },
                "sharedRuleProfileRefs": {
                  "items": {
                    "ref": "app.cerulia.defs#ruleProfileRef",
                    "type": "ref"
                  },
                  "type": "array"
                }
              },
              "type": "object"
            },
            "stewardDids": {
              "items": {
                "ref": "app.cerulia.defs#did",
                "type": "ref"
              },
              "type": "array"
            }
          },
          "required": [
            "mode",
            "campaign",
            "publishedArtifacts"
          ],
          "type": "object"
        }
      },
      "parameters": {
        "properties": {
          "campaignRef": {
            "format": "at-uri",
            "type": "string"
          },
          "mode": {
            "enum": [
              "owner-steward",
              "public"
            ],
            "type": "string"
          }
        },
        "required": [
          "campaignRef"
        ],
        "type": "params"
      },
      "type": "query"
    }
  },
  "id": "app.cerulia.rpc.getCampaignView",
  "lexicon": 1
}
