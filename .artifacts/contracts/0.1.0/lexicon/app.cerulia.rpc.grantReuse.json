{
  "defs": {
    "main": {
      "errors": [
        {
          "name": "InvalidRequest"
        },
        {
          "name": "Unauthorized"
        },
        {
          "name": "Forbidden"
        },
        {
          "name": "NotFound"
        },
        {
          "name": "UnsupportedRuleset"
        },
        {
          "name": "InternalError"
        }
      ],
      "input": {
        "encoding": "application/json",
        "schema": {
          "properties": {
            "characterBranchRef": {
              "ref": "app.cerulia.defs#characterBranchRef",
              "type": "ref"
            },
            "expiresAt": {
              "ref": "app.cerulia.defs#datetime",
              "type": "ref"
            },
            "note": {
              "type": "string"
            },
            "requestId": {
              "ref": "app.cerulia.defs#requestId",
              "type": "ref"
            },
            "reuseMode": {
              "ref": "app.cerulia.defs#reuseMode",
              "type": "ref"
            },
            "sourceCampaignRef": {
              "ref": "app.cerulia.defs#sourceCampaignRef",
              "type": "ref"
            },
            "targetDid": {
              "ref": "app.cerulia.defs#targetDid",
              "type": "ref"
            },
            "targetKind": {
              "ref": "app.cerulia.defs#reuseTargetKind",
              "type": "ref"
            },
            "targetRef": {
              "ref": "app.cerulia.defs#targetRef",
              "type": "ref"
            }
          },
          "required": [
            "characterBranchRef",
            "sourceCampaignRef",
            "targetKind",
            "reuseMode",
            "requestId"
          ],
          "type": "object"
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "ref": "app.cerulia.defs#mutationAck",
          "type": "ref"
        }
      },
      "type": "procedure"
    }
  },
  "id": "app.cerulia.rpc.grantReuse",
  "lexicon": 1
}
