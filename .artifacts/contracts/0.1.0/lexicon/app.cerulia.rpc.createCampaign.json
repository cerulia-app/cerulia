{
  "defs": {
    "main": {
      "errors": [
        {
          "name": "InvalidRequest"
        },
        {
          "name": "Unauthorized"
        },
        {
          "name": "Forbidden"
        },
        {
          "name": "NotFound"
        },
        {
          "name": "UnsupportedRuleset"
        },
        {
          "name": "InternalError"
        }
      ],
      "input": {
        "encoding": "application/json",
        "schema": {
          "properties": {
            "defaultReusePolicyKind": {
              "ref": "app.cerulia.defs#reusePolicyKind",
              "type": "ref"
            },
            "houseRef": {
              "ref": "app.cerulia.defs#houseRef",
              "type": "ref"
            },
            "requestId": {
              "ref": "app.cerulia.defs#requestId",
              "type": "ref"
            },
            "rulesetManifestRef": {
              "ref": "app.cerulia.defs#rulesetManifestRef",
              "type": "ref"
            },
            "rulesetNsid": {
              "ref": "app.cerulia.defs#rulesetNsid",
              "type": "ref"
            },
            "sharedRuleProfileRefs": {
              "items": {
                "ref": "app.cerulia.defs#ruleProfileRef",
                "type": "ref"
              },
              "type": "array"
            },
            "stewardDids": {
              "items": {
                "ref": "app.cerulia.defs#did",
                "type": "ref"
              },
              "minLength": 1,
              "type": "array"
            },
            "title": {
              "type": "string"
            },
            "visibility": {
              "ref": "app.cerulia.defs#visibility",
              "type": "ref"
            },
            "worldRef": {
              "ref": "app.cerulia.defs#worldRef",
              "type": "ref"
            }
          },
          "required": [
            "title",
            "visibility",
            "rulesetNsid",
            "rulesetManifestRef",
            "defaultReusePolicyKind",
            "stewardDids",
            "requestId"
          ],
          "type": "object"
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "ref": "app.cerulia.defs#mutationAck",
          "type": "ref"
        }
      },
      "type": "procedure"
    }
  },
  "id": "app.cerulia.rpc.createCampaign",
  "lexicon": 1
}
