{
  "defs": {
    "main": {
      "errors": [
        {
          "name": "InvalidRequest"
        },
        {
          "name": "Unauthorized"
        },
        {
          "name": "Forbidden"
        },
        {
          "name": "NotFound"
        },
        {
          "name": "UnsupportedRuleset"
        },
        {
          "name": "InternalError"
        }
      ],
      "input": {
        "encoding": "application/json",
        "schema": {
          "properties": {
            "entryUrl": {
              "format": "uri",
              "type": "string"
            },
            "expectedCurrentHeadRef": {
              "ref": "app.cerulia.defs#publicationRef",
              "type": "ref"
            },
            "note": {
              "type": "string"
            },
            "preferredSurfaceKind": {
              "ref": "app.cerulia.defs#publicationSurfaceKind",
              "type": "ref"
            },
            "requestId": {
              "ref": "app.cerulia.defs#requestId",
              "type": "ref"
            },
            "reuseGrantRef": {
              "ref": "app.cerulia.defs#reuseGrantRef",
              "type": "ref"
            },
            "subjectKind": {
              "ref": "app.cerulia.defs#publicationSubjectKind",
              "type": "ref"
            },
            "subjectRef": {
              "ref": "app.cerulia.defs#subjectRef",
              "type": "ref"
            },
            "surfaces": {
              "items": {
                "ref": "app.cerulia.defs#surfaceDescriptor",
                "type": "ref"
              },
              "minLength": 1,
              "type": "array"
            }
          },
          "required": [
            "subjectRef",
            "subjectKind",
            "entryUrl",
            "preferredSurfaceKind",
            "surfaces",
            "requestId"
          ],
          "type": "object"
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "ref": "app.cerulia.defs#mutationAck",
          "type": "ref"
        }
      },
      "type": "procedure"
    }
  },
  "id": "app.cerulia.rpc.publishSubject",
  "lexicon": 1
}
