{
	"name": "@cerulia/api",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun run src/entrypoints/bun.ts",
		"dev:e2e": "bun run src/entrypoints/bun-e2e.ts",
		"dev:worker": "bun x wrangler dev",
		"build": "tsc --noEmit",
		"migrate": "bun run scripts/migrate-sqlite.mjs",
		"migrate:d1:local": "bun x wrangler d1 migrations apply cerulia-api --local",
		"migrate:d1:remote": "bun x wrangler d1 migrations apply cerulia-api --remote",
		"test": "bun test",
		"check": "tsc --noEmit && bun test"
	},
	"dependencies": {
		"@atproto-labs/handle-resolver": "^0.3.6",
		"@atproto-labs/identity-resolver": "^0.3.6",
		"@atproto/api": "^0.19.9",
		"@atproto/common-web": "^0.4.21",
		"@atproto/jwk-jose": "^0.1.11",
		"@atproto/jwk-webcrypto": "^0.2.0",
		"@atproto/lexicon": "^0.6.2",
		"@atproto/oauth-client": "^0.6.0",
		"@atproto/oauth-client-node": "^0.3.17",
		"@cerulia/protocol": "workspace:*",
		"@ipld/dag-cbor": "^9.2.6",
		"hono": "^4.10.0",
		"multiformats": "^13.4.2"
	},
	"devDependencies": {
		"wrangler": "^4.41.0"
	}
}
