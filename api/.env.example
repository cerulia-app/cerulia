# Bun self-host defaults
PORT=8787
CERULIA_API_DB=./cerulia-api.sqlite
CERULIA_ENABLE_HEADER_AUTH_SHIM=0
CERULIA_DOH_ENDPOINT=https://cloudflare-dns.com/dns-query

# Enable OAuth BFF only when both values are set.
# CERULIA_PUBLIC_BASE_URL=https://cerulia.example.com
# CERULIA_OAUTH_PRIVATE_JWK={"kty":"EC","crv":"P-256","x":"...","y":"...","d":"..."}
# CERULIA_OAUTH_CLIENT_NAME=Cerulia

# Workers use the same CERULIA_* names via Wrangler vars/secrets.
# The D1 binding `DB` is configured in wrangler.toml, not in .env.