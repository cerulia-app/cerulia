{
	"name": "cerulia",
	"private": true,
	"packageManager": "bun@1.3.11",
	"workspaces": [
		"appview",
		"api",
		"protocol",
		"projection"
	],
	"scripts": {
		"check": "bun run --sequential --filter '@cerulia/protocol' --filter '@cerulia/api' --filter '@cerulia/projection' check && bun run --filter '@cerulia/appview' verify",
		"build": "bun run --sequential --workspaces --if-present build",
		"test": "bun run --sequential --workspaces --if-present test",
		"test:e2e": "bun run --cwd=appview test:e2e",
		"test:e2e:core": "bun run --cwd=appview test:e2e:core",
		"test:e2e:discovery": "bun run --cwd=appview test:e2e:discovery",
		"test:e2e:oauth": "bun run --cwd=appview test:e2e:oauth",
		"typecheck": "bun run --sequential --filter '@cerulia/protocol' --filter '@cerulia/api' --filter '@cerulia/projection' build && bun run --filter '@cerulia/appview' check",
		"dev:appview": "bun run --cwd=appview dev",
		"dev:api": "bun run --cwd=api dev",
		"dev:api:worker": "bun run --cwd=api dev:worker",
		"dev:projection": "bun run --cwd=projection dev",
		"dev:projection:worker": "bun run --cwd=projection dev:worker",
		"lint": "biome lint .",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/bun": "^1.3.12",
		"typescript": "^6.0.3"
	}
}
